# Application
PORT=3000
NODE_ENV=development

# MongoDB connection URI
# For local development: mongodb://localhost:27017/import-legacy
# For Docker Compose: mongodb://mongo:27017/import-legacy
MONGODB_URI=mongodb://mongo:27017/import-legacy

# Redis connection settings
# For local development use localhost; for Docker Compose use the service name 'redis'
REDIS_HOST=redis
REDIS_PORT=6379

# File upload limit in megabytes (default: 50)
MAX_FILE_SIZE_MB=50

# Winston log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Number of concurrent import worker threads
WORKER_CONCURRENCY=2

# Number of records per batch insert
BATCH_SIZE=100
